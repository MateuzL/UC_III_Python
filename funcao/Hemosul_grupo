def criterios():
    try:
        peso = float(input("Qual seu peso em kg?(quilogramas): "))
    except ValueError:
        print("Peso inválido")
        return
    if peso < 51:
        print("Você não pode doar sangue")
        menu()
        return
    try:
        idade = int(input("Qual a sua idade? "))
    except ValueError:
        print("Idade inválida")
        return

    if idade < 16 or idade > 60:
        print("Você não pode doar sangue.")
        menu()
        return
    if idade >= 16 and idade <= 17:
        try:
            pais = int(input("Você está acompanhado de um responsável?  (1-SIM/2-NAO) "))
        except ValueError:
            print("Opção inválida")
            return
        if pais == 0:
            print("Você não pode doar sangue")
            menu()
            return
        elif pais != 1:
            print("Opção inválida")
            menu()
            return
    try:
        saude = int(input("Você está em boas condições de saúde? (1-SIM/0-NAO) "))
    except ValueError:
        print("Opção inválida")
        return
    if saude == 0:
        print("Você não pode doar sangue")
        menu()
        return
    elif saude != 1:
        print("Opção inválida")
        menu()
        return
    try:
        bemestar = int(input("Você está devidamente alimentado e descansado? (1-SIM/0-NAO) "))
    except ValueError:
        print("Opção inválida")
        return
    if bemestar == 0:
        print("Você não pode doar sangue")
        menu()
    elif bemestar == 1:
        print("Você pode doar sangue se não se enquadrar nesses requisitos: \n")
        inibicoes()
    else:
        print("Opção inválida")
        menu()
    
